            ave_f1=abs(ca4(z,i,2,m,j))*j+ave_f1;
            ave_h=abs(ca4(z,i,1,m,j))*z+ave_h;
            ave_h1=abs(ca4(z,i,2,m,j))*z+ave_h1;
            total_a=total_a+abs(ca4(z,i,1,m,j));
