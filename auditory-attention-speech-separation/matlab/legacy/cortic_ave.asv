clear ca32
clc
ave=ave_kol;
save('ave','ave');
[l,m,n]=size(ave);
rave=reshape(ave,l*m,[]);%reshape ave
% khate zir baraie azmaiesh e
[rave,pr]=mapstd(rave,0,1); %mapstd rave
save('rave','rave');
end






            
            